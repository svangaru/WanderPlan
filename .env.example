# Database
# Local Docker default. For Supabase/Neon: DATABASE_URL = pooled connection
# (Supabase port 6543, append ?pgbouncer=true), DIRECT_URL = direct connection
# (port 5432). Prisma uses DIRECT_URL for migrations and DATABASE_URL at runtime.
DATABASE_URL="postgresql://wanderplan:wanderplan_dev@localhost:5432/wanderplan"
DIRECT_URL="postgresql://wanderplan:wanderplan_dev@localhost:5432/wanderplan"

# Redis (optional locally — rate limiting falls back to in-memory if unset)
REDIS_URL="redis://localhost:6379"

# Anthropic API — server-side only, never exposed to the client
ANTHROPIC_API_KEY=""
# Model id. Defaults to a Haiku-class model to keep cost low. Bump to a
# Sonnet-class id (e.g. claude-sonnet-4-6) for higher-quality itineraries.
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-min-32-chars-change-in-prod"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Mapbox (optional, Phase C) — SVG Italy fallback renders without it
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Generation engine: mock | live. Default mock = zero API tokens in dev.
GENERATION_ENGINE="mock"

# --- Cost guardrails (all optional; shown values are the defaults) ---
# Per-user daily caps on AI calls.
GEN_DAILY_FULL_LIMIT="10"
GEN_DAILY_DAY_LIMIT="40"
# Trips longer than this never use the live engine (forces cheap mock).
GEN_MAX_LIVE_DAYS="21"
# Output token budgets per call.
GEN_LIVE_MAX_TOKENS="8000"
GEN_LIVE_DAY_MAX_TOKENS="1500"
# Pricing used only to estimate logged cost (USD per million tokens).
MODEL_INPUT_USD_PER_MTOK="1.0"
MODEL_OUTPUT_USD_PER_MTOK="5.0"

# Environment
NODE_ENV="development"
