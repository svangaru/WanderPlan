# Database
DATABASE_URL="postgresql://wanderplan:wanderplan_dev@localhost:5432/wanderplan"

# Redis
REDIS_URL="redis://localhost:6379"

# Anthropic API (add during Phase B)
ANTHROPIC_API_KEY=""

# NextAuth (add during Phase B)
NEXTAUTH_SECRET="your-secret-key-min-32-chars-change-in-prod"
